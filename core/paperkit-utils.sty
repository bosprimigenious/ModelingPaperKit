% ============================================================
%  paperkit-utils.sty — 算法、写作标记、脱敏占位
%  选项: zh | en | auto
%
% 命令: \todo, \draft, \email, \phone, \upcite
% 算法: algorithm + algpseudocode（已汉化/英文化）
% ============================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{paperkit-utils}[2026/05/18 v1.0 ModelingPaperKit Utilities]

\makeatletter
\newif\ifpkuLangZh
\newif\ifpkuLangSet
\DeclareOption{zh}{\pkuLangZhtrue\pkuLangSettrue}
\DeclareOption{en}{\pkuLangZhfalse\pkuLangSettrue}
\DeclareOption{auto}{}
\ExecuteOptions{auto}
\ProcessOptions\relax
\ifpkuLangSet\else
  \@ifclassloaded{ctexart}{\pkuLangZhtrue}{%
    \@ifclassloaded{ctexrep}{\pkuLangZhtrue}{%
      \@ifclassloaded{ctexbook}{\pkuLangZhtrue}{%
        \@ifpackageloaded{ctex}{\pkuLangZhtrue}{\pkuLangZhfalse}%
      }}%
  }%
\fi
\makeatother

% ── 算法伪代码 ──
\RequirePackage{algorithm}
\RequirePackage{algorithmicx}
\RequirePackage{algpseudocode}

\ifpkuLangZh
  \floatname{algorithm}{算法}
  \renewcommand{\listalgorithmname}{算法清单}
\else
  \floatname{algorithm}{Algorithm}
  \renewcommand{\listalgorithmname}{List of Algorithms}
\fi

% 中文 algorithmic 汉化（补齐 algpseudocode 常用关键字）
\ifpkuLangZh
\algrenewcommand\algorithmicrequire{\textbf{输入：}}
\algrenewcommand\algorithmicensure{\textbf{输出：}}
\algrenewcommand\algorithmicwhile{\textbf{当}}
\algrenewcommand\algorithmicdo{\textbf{执行}}
\algrenewcommand\algorithmicend{\textbf{结束}}
\algrenewcommand\algorithmicif{\textbf{如果}}
\algrenewcommand\algorithmicthen{\textbf{则}}
\algrenewcommand\algorithmicelse{\textbf{否则}}
\algrenewcommand\algorithmicfor{\textbf{遍历}}
\algrenewcommand\algorithmicforall{\textbf{对所有}}
\algrenewcommand\algorithmicloop{\textbf{循环}}
\algrenewcommand\algorithmicfunction{\textbf{函数}}
\algrenewcommand\algorithmicprocedure{\textbf{过程}}
\algrenewcommand\algorithmicreturn{\textbf{返回}}
\algrenewcommand\algorithmicrepeat{\textbf{重复}}
\algrenewcommand\algorithmicuntil{\textbf{直到}}
% TODO(director): algorithmicstate/and/or/not/print 在 algpseudocode 中无对应命令，是否自定义？
\algrenewcommand\algorithmiccomment[1]{\hfill\textit{// ##1}}
\else
\algrenewcommand\algorithmicrequire{\textbf{Require:}}
\algrenewcommand\algorithmicensure{\textbf{Ensure:}}
\algrenewcommand\algorithmicwhile{\textbf{while}}
\algrenewcommand\algorithmicdo{\textbf{do}}
\algrenewcommand\algorithmicend{\textbf{end}}
\algrenewcommand\algorithmicif{\textbf{if}}
\algrenewcommand\algorithmicthen{\textbf{then}}
\algrenewcommand\algorithmicelse{\textbf{else}}
\algrenewcommand\algorithmicfor{\textbf{for}}
\algrenewcommand\algorithmicforall{\textbf{for all}}
\algrenewcommand\algorithmicloop{\textbf{loop}}
\algrenewcommand\algorithmicfunction{\textbf{function}}
\algrenewcommand\algorithmicprocedure{\textbf{procedure}}
\algrenewcommand\algorithmicreturn{\textbf{return}}
\algrenewcommand\algorithmicrepeat{\textbf{repeat}}
\algrenewcommand\algorithmicuntil{\textbf{until}}
\algrenewcommand\algorithmiccomment[1]{\hfill\textit{// ##1}}
\fi

% ── tcolorbox 代码块 ──
\RequirePackage[most]{tcolorbox}
\tcbuselibrary{listings,breakable}

% ── 写作过程标记 ──
\RequirePackage{xcolor}
\definecolor{pkb@todobg}{RGB}{255, 244, 204}
\definecolor{pkb@draftbg}{RGB}{255, 230, 230}
\newcommand{\todo}[1]{%
  \par\noindent{\color{orange}\textbf{[TODO]}}~#1\par
}
\providecommand{\draft}[1]{%
  \par\noindent{\color{red!70!black}\textbf{[DRAFT]}}~#1\par
}
\ifpkuLangZh
  \renewcommand{\draft}[1]{%
    \par\noindent{\color{red!70!black}\textbf{[草稿]}}~#1\par
  }
\fi

% ── 脱敏占位（编译期自动替换） ──
\newcommand{\email}[1]{[已脱敏]}
\newcommand{\phone}[1]{[已脱敏]}

% ── 摘要关键词（中英） ──
\newcommand{\keywords}[1]{%
  \par\noindent
  \ifpkuLangZh
    {\ifcsname heiti\endcsname\heiti\else\bfseries\fi 关键词：}%
  \else
    {\bfseries Keywords:}%
  \fi
  ~#1\par
}

% 上标引用见 paperkit-math.sty 的 \upcite
\newcommand{\supercite}[1]{\textsuperscript{\textsuperscript{\cite{#1}}}}

% ── 实用宏 ──
% 正文插图统一宽度
\newcommand{\BodyFigWidth}{0.76\textwidth}
% 流程类 PDF 最大高度
\newcommand{\BodyPdfMaxHeight}{0.36\textheight}

% ── hyperref（必须在所有宏包之后加载） ──
\RequirePackage{hyperref}
\hypersetup{
  colorlinks=true,
  linkcolor=black,
  citecolor=black,
  urlcolor=black
}

% ── cleveref（须在 hyperref 之后） ──
\RequirePackage{cleveref}
\makeatletter
\ifpkuLangZh
  \crefname{figure}{图}{图}%
  \crefname{table}{表}{表}%
  \crefname{equation}{式}{式}%
  \crefname{algorithm}{算法}{算法}%
\else
  \crefformat{figure}{Fig.~##2##1##3}%
  \crefformat{table}{Table~##2##1##3}%
  \crefformat{equation}{Eq.~##2##1##3}%
  \Crefformat{figure}{Figure~##2##1##3}%
  \Crefformat{table}{Table~##2##1##3}%
  \Crefformat{equation}{Equation~##2##1##3}%
  \crefformat{theorem}{Theorem~##2##1##3}%
  \crefformat{lemma}{Lemma~##2##1##3}%
  \crefformat{definition}{Definition~##2##1##3}%
  \crefformat{corollary}{Corollary~##2##1##3}%
  \crefformat{assumption}{Assumption~##2##1##3}%
  \crefformat{remark}{Remark~##2##1##3}%
  \crefformat{property}{Property~##2##1##3}%
  \crefformat{example}{Example~##2##1##3}%
  \Crefformat{theorem}{Theorem~##2##1##3}%
  \Crefformat{lemma}{Lemma~##2##1##3}%
  \Crefformat{definition}{Definition~##2##1##3}%
  \crefmultiformat{figure}{(Figs.~##2##1##3)}%
  \crefmultiformat{table}{(Tables~##2##1##3)}%
  \crefmultiformat{equation}{(Eqs.~##2##1##3)}%
  \crefmultiformat{theorem}{(Theorems~##2##1##3)}%
  \crefmultiformat{lemma}{(Lemmas~##2##1##3)}%
  \crefmultiformat{definition}{(Definitions~##2##1##3)}%
  \crefrangeformat{figure}{Figs.~##3##1##2--##5}%
  \crefrangeformat{table}{Tables~##3##1##2--##5}%
  \crefrangeformat{equation}{Eqs.~##3##1##2--##5}%
  \crefrangeformat{theorem}{Theorems~##3##1##2--##5}%
  \crefrangeformat{lemma}{Lemmas~##3##1##2--##5}%
  \crefrangeformat{definition}{Definitions~##3##1##2--##5}%
\fi
\makeatother

\endinput
