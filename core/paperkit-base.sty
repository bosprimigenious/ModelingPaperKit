% ============================================================
%  paperkit-base.sty — ModelingPaperKit 核心排版引擎
%
% 主要命令:
%   \figplot{caption}{height}{label}{placeholder}{file}{note}
%   \FigPlotSubContent{a}{b}{file}  — 子图内容
%   \topline / \midline / \bottomline — 三线表
%   列类型 Y (居中 X), J (左对齐 X)
% ============================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{paperkit-base}[2026/05/18 v1.0 ModelingPaperKit Base Engine]

% ── 基础宏包 ──
\RequirePackage{xurl}
\RequirePackage{geometry}
\RequirePackage{setspace}
\RequirePackage{graphicx}
\RequirePackage{float}
\RequirePackage{caption}
\RequirePackage{subcaption}
\RequirePackage{enumitem}
\RequirePackage{xcolor}
\RequirePackage{titlesec}
\RequirePackage{etoolbox}
\RequirePackage{xparse}
\RequirePackage{fontspec}

\RequireXeTeX

% ── 页面边距 ──
\geometry{
  a4paper,
  left=3.17cm,
  right=3.17cm,
  top=2.54cm,
  bottom=2.54cm,
  headheight=0pt,
  headsep=0pt,
  footskip=1.25cm,
  bindingoffset=0pt
}

% ── 浮动体版面参数（参考 CUMCMThesis） ──
\renewcommand*{\textfraction}{0.05}
\renewcommand*{\topfraction}{0.9}
\renewcommand*{\bottomfraction}{0.8}
\renewcommand*{\floatpagefraction}{0.85}

% ── 插图搜索路径与扩展名 ──
\DeclareGraphicsExtensions{.pdf,.png,.jpg,.jpeg,.eps}
\graphicspath{{./figures/}{../02_figures/}}

% ── 正文字体与行距 (可由模板覆盖) ──
\providecommand{\pkb@mainfont}{Times New Roman}
\providecommand{\pkb@cjkmainfont}{SimSun}
\providecommand{\pkb@cjkheifont}{SimHei}
\providecommand{\pkb@cjkkaifont}{KaiTi}

\makeatletter
% ctexart 自行管理 CJK 字体；article 模板在 main 中设置 \setmainfont
\@ifpackageloaded{ctex}{}{%
  \setmainfont{\pkb@mainfont}%
}
\makeatother

\raggedbottom
\setlength{\parindent}{2em}
\setlength{\parskip}{0pt}
\emergencystretch=3.5em\relax

% ── 页眉页脚：无页眉，只保留页脚居中页码 ──
\pagestyle{plain}
\makeatletter
\def\ps@plain{%
  \let\@oddhead\@empty
  \let\@evenhead\@empty
  \def\@oddfoot{\hfil\pkb@printpage\hfil}%
  \def\@evenfoot{\hfil\pkb@printpage\hfil}%
}
\newcommand{\pkb@printpage}{%
  \ifcsname zihao\endcsname\zihao{-5}\else\small\fi\thepage%
}
\makeatother

% ── caption 设置 ──
\captionsetup{
  font={small},
  labelfont={bf},
  labelsep=quad,
  justification=centering,
  skip=4pt
}

% ── 浮动体间距 ──
\setlength{\textfloatsep}{10pt plus 3pt minus 3pt}
\setlength{\floatsep}{10pt plus 3pt minus 3pt}
\setlength{\intextsep}{8pt plus 3pt minus 3pt}

% ── 列表（紧凑，节省版面） ──
\setlist{
  topsep=0.3em,
  itemsep=0ex plus 0.1ex,
  leftmargin=1.5em,
  parsep=0pt,
  partopsep=0pt
}

% ── 图表题注：仅中文模板汉化（ctex 已内置时可安全覆盖） ──
\makeatletter
\@ifpackageloaded{ctex}{%
  \renewcommand{\tablename}{表}%
  \renewcommand{\figurename}{图}%
}{}
\makeatother

\AtBeginEnvironment{table}{\centering}

% ── 插图占位字体（跨 ctexart / article） ──
\NewDocumentCommand{\pkbFigTitleWrap}{m}{%
  {\ifcsname heiti\endcsname\heiti\else\bfseries\fi #1}%
}
\NewDocumentCommand{\pkbFigNoteWrap}{m}{%
  {\ifcsname zihao\endcsname\zihao{5}\else\small\fi #1}%
}
\newcommand{\pkbFigNoteLabel}{%
  \ifcsname heiti\endcsname 制图说明：\else Figure note:\fi
}

% ── 图片占位 / 自动插图宏 ──
% \figplot{题注}{占位高度}{label}{占位说明}{文件名}{制图说明(可空)}
\NewDocumentCommand{\figplot}{mmmmmm}{%
  \begin{figure}[H]
    \centering
    \def\pkbFigPath{}%
    \IfFileExists{#5}{\edef\pkbFigPath{#5}}{}%
    \IfFileExists{./figures/#5}{%
      \ifx\pkbFigPath\empty\edef\pkbFigPath{./figures/#5}\fi
    }{}%
    \IfFileExists{../02_figures/#5}{%
      \ifx\pkbFigPath\empty\edef\pkbFigPath{../02_figures/#5}\fi
    }{}%
    \ifx\pkbFigPath\empty
      \fbox{%
        \parbox[c][#2][c]{0.845\textwidth}{%
          \centering
          \pkbFigTitleWrap{#1}\\[0.8em]
          \pkbFigNoteWrap{#4}%
        }%
      }%
    \else
      \includegraphics[width=0.845\textwidth]{\pkbFigPath}%
    \fi
    \caption{#1}%
    \ifblank{#6}{}{%
      \begingroup
      \setlength{\parindent}{0pt}%
      \vspace{0.35em}%
      \noindent{\ifcsname heiti\endcsname\heiti\else\bfseries\fi
        \textbf{\pkbFigNoteLabel}}%
      \pkbFigNoteWrap{#6}\par
      \endgroup
    }%
    \label{#3}%
  \end{figure}%
}

% ── 子图内插图 ──
\NewDocumentCommand{\FigPlotSubContent}{mmm}{%
  \includegraphics[width=\linewidth]{#3}%
}

\captionsetup[subfigure]{font=small,skip=4pt}

% ── 代码列表 ──
\RequirePackage{listings}
\lstset{
  basicstyle=\ttfamily\small,
  breaklines=true,
  breakatwhitespace=true,
  linewidth=0.94\textwidth,
  frame=single,
  numbers=left,
  numberstyle=\tiny,
  keywordstyle=\bfseries,
  commentstyle=\itshape,
  columns=fullflexible,
  tabsize=4,
  showstringspaces=false
}

% ── 表格增强 ──
\RequirePackage{booktabs}
\RequirePackage{array}
\RequirePackage{makecell}
\RequirePackage{tabularx}
\RequirePackage{longtable}
\setlength{\LTcapwidth}{\textwidth}
\renewcommand{\theadfont}{\bfseries}
\setlength{\heavyrulewidth}{0.9pt}
\setlength{\lightrulewidth}{0.55pt}
\setlength{\cmidrulewidth}{0.55pt}
\renewcommand{\arraystretch}{1.18}

\newcommand{\topline}{\toprule}
\newcommand{\midline}{\midrule}
\newcommand{\bottomline}{\bottomrule}

\newcolumntype{Y}{>{\centering\arraybackslash}X}
\newcolumntype{J}{>{\raggedright\arraybackslash}X}

% hyperref / cleveref 在 paperkit-utils.sty 中于 hyperref 之后加载

% ── 目录格式（仅中文 ctex 模板） ──
\makeatletter
\@ifpackageloaded{ctex}{%
  \RequirePackage{tocloft}%
  \AtBeginDocument{%
    \ifcsname heiti\endcsname
      \cftsecfont{\heiti\zihao{4}}%
    \else
      \cftsecfont{\bfseries\large}%
    \fi
    \cftsecdotsep{4.5}%
    \cftbeforesecskip{7pt}%
  }%
}{}
\makeatother

% ── 图表标题样式（仅中文 ctex 模板；英文保持上方默认） ──
\makeatletter
\@ifpackageloaded{ctex}{%
  \AtBeginDocument{%
    \ifcsname songti\endcsname
      \DeclareCaptionFont{pkb@capzh}{\songti\zihao{-4}}
      \captionsetup[figure]{%
        font={pkb@capzh},
        labelfont={bf,pkb@capzh},
        format=hang,
        position=bottom,
        skip=4pt
      }%
      \captionsetup[table]{%
        font={pkb@capzh},
        labelfont={bf,pkb@capzh},
        format=hang,
        position=top,
        skip=4pt
      }%
    \fi
  }%
}{}
\makeatother

\endinput
